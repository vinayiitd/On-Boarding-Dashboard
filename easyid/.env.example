# =============================================================================
# easyID · root example environment
# Copy this file to `.env` for local development. Do NOT commit `.env`.
# Per-app envs live under `apps/*/.env.example`.
# =============================================================================

# ---- Postgres (used by docker-compose + apps/api) ----------------------------
POSTGRES_USER=easyid
POSTGRES_PASSWORD=easyid
POSTGRES_DB=easyid
POSTGRES_PORT=5432

# ---- API --------------------------------------------------------------------
# Async SQLAlchemy URL — use `postgresql+asyncpg` scheme, not plain `postgres`.
# The docker-compose file wires this automatically inside the api container;
# override here only when running the api on the host.
DATABASE_URL=postgresql+asyncpg://easyid:easyid@localhost:5432/easyid
API_PORT=8000
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000

# ---- Web --------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
WEB_PORT=3000

# =============================================================================
# easyID · root example environment
# Copy this file to `.env` for local development. Do NOT commit `.env`.
# Per-app envs live under `apps/*/.env.example`.
# =============================================================================

# ---- Postgres ---------------------------------------------------------------
POSTGRES_USER=easyid
POSTGRES_PASSWORD=easyid
POSTGRES_DB=easyid
POSTGRES_PORT=5432

# ---- API --------------------------------------------------------------------
ENVIRONMENT=development
API_PORT=8000
API_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000
# Host-side default; Compose overrides this to use the `postgres` service DNS.
DATABASE_URL=postgresql+asyncpg://easyid:easyid@127.0.0.1:5432/easyid

# ---- Web --------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
WEB_PORT=3000

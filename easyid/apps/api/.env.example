# =============================================================================
# apps/api · environment
# Copy to `.env` when running the API on the host (not via docker compose).
# =============================================================================

# --- Database ---
# Async URL — must use the `postgresql+asyncpg` scheme, not `postgresql://`.
DATABASE_URL=postgresql+asyncpg://easyid:easyid@localhost:5432/easyid

# Optional — connection pool tuning.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# --- HTTP ---
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Comma-separated list, or `*` in development.
API_CORS_ORIGINS=http://localhost:3000

# =============================================================================
# apps/api · environment
# Copy to `.env` when running the API on the host (not via docker compose).
# =============================================================================

# --- Meta ---
# ENVIRONMENT=development|test|staging|production
ENVIRONMENT=development
API_LOG_LEVEL=info

# --- HTTP ---
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins. Use `*` only in local development.
API_CORS_ORIGINS=http://localhost:3000

# Optional path prefix when mounted behind a reverse proxy.
API_ROOT_PATH=

# --- OpenAPI ---
OPENAPI_CONTACT_NAME=easyID Engineering
OPENAPI_CONTACT_EMAIL=engineering@easyid.app

# --- Persistence (PostgreSQL via asyncpg) ---
DATABASE_URL=postgresql+asyncpg://easyid:easyid@127.0.0.1:5432/easyid
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_ECHO=false

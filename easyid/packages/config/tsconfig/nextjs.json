{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "easyID · Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "allowJs": false,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "plugins": [{ "name": "next" }]
  }
}

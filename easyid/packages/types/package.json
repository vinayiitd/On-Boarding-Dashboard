{
  "name": "@easyid/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for the easyID monorepo.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src/**",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf .turbo dist",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@easyid/config": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "~5.7.2"
  }
}
